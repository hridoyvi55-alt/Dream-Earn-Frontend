# ============================================
# Firebase Client Configuration
# ============================================
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ============================================
# Firebase App Check (Security Layer)
# ============================================
VITE_FIREBASE_APP_CHECK_SITE_KEY=your_app_check_site_key_here

# ============================================
# Backend API (Cloud Functions / Server)
# ============================================
VITE_BACKEND_URL=https://your_project_id.cloudfunctions.net

# ============================================
# Frontend Deployment URL
# ============================================
VITE_APP_URL=https://your-domain.com

# ============================================
# Ad Providers (Optional - frontend exposed)
# ============================================
VITE_ADSTERRA_KEY=your_adsterra_key_here
VITE_MONETAG_KEY=your_monetag_key_here

# ============================================
# Environment Mode
# ============================================
VITE_NODE_ENV=development
